# Local-only configuration for cursor-transcript-backup.
# Copy this file to .env and fill in your own values.
#
# Do not commit .env. It may contain private server/share names.

# Examples:
#   Windows mapped drive: T:\Transcripts-2026
#   Windows UNC path:    \\server.example.edu\Transcripts-2026
#   Linux/Samba mount:   /mnt/transcripts-2026
CURSOR_TRANSCRIPT_DEST_ROOT=

# Example: First-Last or First-Middle-Last
CURSOR_TRANSCRIPT_PERSON_FOLDER=

# Optional. Defaults to ~/.cursor/projects.
CURSOR_TRANSCRIPT_SOURCE_ROOT=

